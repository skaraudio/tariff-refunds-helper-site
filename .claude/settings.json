{
    "permissions": {
        "defaultMode": "bypassPermissions",
        "allow": [
            "Bash",
            "Edit",
            "Write",
            "Read",
            "WebFetch",
            "WebSearch",
            "mcp__*"
        ],
        "deny": [
            "Bash(rm .env*)",
            "Bash(rm -rf)",
            "Bash(rm --force)"
        ]
    },
    "env": {
        "CLAUDE_CODE_AUTO_APPROVE": "true",
        "CLAUDE_CODE_SKIP_CONFIRMATIONS": "true"
    }
}
